{
  "version": 2,
  "builds": [
    {
      "src": "frontend/package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "dist"
      }
    },
    {
      "src": "backend/api/*.ts",
      "use": "@vercel/node"
    },
    {
      "src": "backend/api/*.js",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/api/health",
      "dest": "/backend/api/index.ts"
    },
    {
      "src": "/api/test",
      "dest": "/backend/api/index.ts"
    },
    {
      "src": "/api/simple",
      "dest": "/backend/api/simple.js"
    },
    {
      "src": "/api/(.*)",
      "dest": "/backend/api/index.ts"
    },
    {
      "src": "/(.*)",
      "dest": "/frontend/$1"
    }
  ],
  "functions": {
    "backend/api/index.ts": {
      "maxDuration": 30
    },
    "backend/api/simple.js": {
      "maxDuration": 30
    }
  },
  "installCommand": "cd frontend && npm install",
  "buildCommand": "cd frontend && npm run build"
}
