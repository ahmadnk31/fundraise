# Root level gitignore for fundraising platform

# Environment variables (all levels)
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
.env.*.local
.env.staging
.env.production

# Dependencies
node_modules/
*/node_modules/

# Build outputs
dist/
build/
*/dist/
*/build/

# Logs
*.log
logs/
*/logs/

# Database files
*.db
*.sqlite
*.sqlite3

# Temporary files
tmp/
temp/
*/tmp/
*/temp/

# IDE and editor files
.vscode/
.idea/
*.swp
*.swo

# OS generated files
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# Secrets and sensitive files
secrets/
keys/
*.private
*.secret
*.key
*.pem
*.crt
*.cert

# AWS credentials
.aws/
aws-credentials.json

# Stripe configuration
stripe-webhook-secret.txt
stripe-keys.json
stripe-config.json
.stripe-*

# JWT secrets
jwt-secret.txt
auth-keys.json
.jwt-*

# Database backups
*.sql
*.dump
backup/
backups/

# Upload directories
uploads/
temp-uploads/
*/uploads/
*/temp-uploads/

# Cache directories
.cache/
.parcel-cache/
*/.cache/
*/.parcel-cache/

# Coverage reports
coverage/
*/coverage/

# Docker files (sensitive)
docker-compose.override.yml
.dockerignore.local

# Terraform state
*.tfstate
*.tfstate.*
.terraform/

# Application specific
config.json
secrets.json
payment-keys.json

# Git directories (for subprojects)
.git/
*/.git/
